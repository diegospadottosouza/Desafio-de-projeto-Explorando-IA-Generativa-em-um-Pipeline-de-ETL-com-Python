import openai

def gerar_resumo(df):
    texto = df.to_string(index=False)
    prompt = f"Analise os dados de vendas abaixo e gere um resumo estratégico:\n{texto}"

    response = openai.Completion.create(
        engine="text-davinci-003",
        prompt=prompt,
        max_tokens=100,
        temperature=0.7
    )

    return response.choices[0].text.strip()
